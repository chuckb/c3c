// #target: elf-riscv32
module test;

fn void main(String[] args)
{
	asm
	{
		li $s1, -65536;
		lui $t0, 123456u;
		auipc $x15, -123456;
		mv $a0, $a1;
		lw $a2, -4, $a3;
		lw $a4, 2047, $zero;
		lb $a5, -2048, $a7;
	}
}

